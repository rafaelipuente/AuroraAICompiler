config.aurora_tools_dir = "@CMAKE_BINARY_DIR@/bin"
config.aurora_src_root = "@CMAKE_SOURCE_DIR@"
config.aurora_obj_root = "@CMAKE_BINARY_DIR@"
config.llvm_tools_dir = "@LLVM_TOOLS_BINARY_DIR@"

import lit.llvm
